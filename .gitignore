# Dependencies
node_modules/
.yarn/cache
.yarn/install-state.gz

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key
# NOTE: google-services.json / GoogleService-Info.plist are intentionally NOT
# ignored — EAS Build only uploads git-tracked files, and app.json references
# google-services.json. These client config files ship inside the app binary
# anyway (their keys are package-restricted, not real secrets).

# Build output
dist/
build/
*.tsbuildinfo

# Expo / React Native
.expo/
.expo-shared/
mobile/web-build/
*.jks
*.p8
*.p12
*.mobileprovision
*.orig.*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backups
*.bak
package-lock.json.bak

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# Test / coverage
coverage/
